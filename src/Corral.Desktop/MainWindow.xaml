<?xml version="1.0" encoding="utf-8"?>

<Window
  x:Class="Corral.Desktop.MainWindow"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
  xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
  xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
  xmlns:viewModels="clr-namespace:Corral.Desktop.ViewModels"
  xmlns:views="clr-namespace:Corral.Desktop.Views"
  xmlns:loc="clr-namespace:Corral.Desktop.Localization"
  mc:Ignorable="d"
  d:DataContext="{d:DesignInstance Type=viewModels:MainWindowViewModel, IsDesignTimeCreatable=True}"
  Style="{DynamicResource CustomWindowStyle}"
  Title="{x:Static loc:Strings.AppTitle}"
  Width="1400"
  Height="900"
  WindowStartupLocation="CenterScreen"
  AllowDrop="True">

  <!-- ========================================
       BEHAVIORS - Wire up ViewModel commands
       ======================================== -->
  <i:Interaction.Triggers>
    <i:EventTrigger EventName="Loaded">
      <i:InvokeCommandAction Command="{Binding InitializeCommand}" />
    </i:EventTrigger>
  </i:Interaction.Triggers>

  <Window.Resources>
    <ResourceDictionary>
      <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary
          Source="pack://application:,,,/Corral.Desktop;component/Resources/DataTemplates.xaml" />
        <ResourceDictionary
          Source="pack://application:,,,/Corral.Desktop;component/Resources/Styles.xaml" />
      </ResourceDictionary.MergedDictionaries>

      <!-- View mapping for navigation -->
      <DataTemplate DataType="{x:Type viewModels:ZonesViewModel}">
        <views:ZonesView />
      </DataTemplate>
      <DataTemplate DataType="{x:Type viewModels:SettingsViewModel}">
        <views:SettingsView />
      </DataTemplate>
    </ResourceDictionary>
  </Window.Resources>

  <Grid>
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="240" />
      <ColumnDefinition Width="*" />
    </Grid.ColumnDefinitions>

    <!-- ========================================
         SIDEBAR - Navigation Panel
         ======================================== -->
    <Border Grid.Column="0"
            Background="{StaticResource BrushSurfaceVariant}">
      <Grid>
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto" />
          <RowDefinition Height="*" />
          <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Logo/Brand -->
        <StackPanel Grid.Row="0"
                    Margin="24,32,24,32">
          <TextBlock
            Text="{x:Static loc:Strings.AppName}"
            FontSize="18"
            FontWeight="Bold"
            Foreground="{StaticResource BrushTextPrimary}"
            Margin="0,0,0,4" />
          <TextBlock
            Text="V0.1.0"
            FontSize="10"
            Foreground="{StaticResource BrushTextTertiary}" />
        </StackPanel>

        <!-- Navigation -->
        <StackPanel Grid.Row="1">
          <!-- Home -->
          <Button Style="{StaticResource ButtonNavigation}"
                  Margin="0,2,0,2">
            <StackPanel Orientation="Horizontal"
                        Margin="24,4">
              <iconPacks:PackIconMaterial Kind="Home"
                                          Margin="0,0,12,0"
                                          Width="14"
                                          Height="14"
                                          Foreground="{StaticResource BrushTextSecondary}"
                                          VerticalAlignment="Center" />
              <TextBlock Text="{x:Static loc:Strings.Nav_Home}"
                         FontSize="13"
                         VerticalAlignment="Center" />
            </StackPanel>
          </Button>

          <!-- Zones -->
          <Button Command="{Binding NavigateToZonesCommand}"
                  Margin="0,2,0,2">
            <StackPanel Orientation="Horizontal"
                        Margin="24,4">
              <iconPacks:PackIconMaterial Kind="ViewGrid"
                                          Margin="0,0,12,0"
                                          Width="14"
                                          Height="14"
                                          Foreground="{Binding CurrentViewModel, Converter={StaticResource ViewModelForegroundConverter}, ConverterParameter=Zones}"
                                          VerticalAlignment="Center" />
              <TextBlock Text="{x:Static loc:Strings.Nav_Zones}"
                         FontSize="13"
                         Foreground="{Binding CurrentViewModel, Converter={StaticResource ViewModelForegroundConverter}, ConverterParameter=Zones}"
                         VerticalAlignment="Center" />
            </StackPanel>
            <Button.Style>
              <Style TargetType="Button"
                     BasedOn="{StaticResource ButtonNavigation}">
                <Style.Triggers>
                  <DataTrigger
                    Binding="{Binding CurrentViewModel, Converter={StaticResource ViewModelTypeConverter}, ConverterParameter=Zones}"
                    Value="True">
                    <Setter Property="Background"
                            Value="{StaticResource BrushSurface}" />
                  </DataTrigger>
                </Style.Triggers>
              </Style>
            </Button.Style>
          </Button>

          <!-- Settings -->
          <Button Command="{Binding NavigateToSettingsCommand}"
                  Margin="0,2,0,2">
            <StackPanel Orientation="Horizontal"
                        Margin="24,4">
              <iconPacks:PackIconMaterial Kind="Cog"
                                          Margin="0,0,12,0"
                                          Width="14"
                                          Height="14"
                                          Foreground="{Binding CurrentViewModel, Converter={StaticResource ViewModelForegroundConverter}, ConverterParameter=Settings}"
                                          VerticalAlignment="Center" />
              <TextBlock Text="{x:Static loc:Strings.Nav_Settings}"
                         FontSize="13"
                         Foreground="{Binding CurrentViewModel, Converter={StaticResource ViewModelForegroundConverter}, ConverterParameter=Settings}"
                         VerticalAlignment="Center" />
            </StackPanel>
            <Button.Style>
              <Style TargetType="Button"
                     BasedOn="{StaticResource ButtonNavigation}">
                <Style.Triggers>
                  <DataTrigger
                    Binding="{Binding CurrentViewModel, Converter={StaticResource ViewModelTypeConverter}, ConverterParameter=Settings}"
                    Value="True">
                    <Setter Property="Background"
                            Value="{StaticResource BrushSurface}" />
                  </DataTrigger>
                </Style.Triggers>
              </Style>
            </Button.Style>
          </Button>
        </StackPanel>

        <!-- Help -->
        <Button Grid.Row="2"
                Style="{StaticResource ButtonNavigation}"
                Margin="0,0,0,24">
          <StackPanel Orientation="Horizontal"
                      Margin="24,4">
            <iconPacks:PackIconMaterial Kind="HelpCircleOutline"
                                        Margin="0,0,12,0"
                                        Width="14"
                                        Height="14"
                                        Foreground="{StaticResource BrushTextSecondary}"
                                        VerticalAlignment="Center" />
            <TextBlock Text="{x:Static loc:Strings.Nav_Help}"
                       FontSize="13"
                       VerticalAlignment="Center" />
          </StackPanel>
        </Button>
      </Grid>
    </Border>

    <!-- ========================================
         MAIN CONTENT AREA
         ======================================== -->
    <Grid Grid.Column="1"
          Background="{StaticResource BrushBackground}">
      <!-- Content View - displays current ViewModel's view via DataTemplate -->
      <ContentControl Content="{Binding CurrentViewModel}" />

      <!-- Window Controls (overlay top-right) -->
      <StackPanel Orientation="Horizontal"
                  VerticalAlignment="Top"
                  HorizontalAlignment="Right"
                  WindowChrome.IsHitTestVisibleInChrome="True">
        <Button Style="{StaticResource TitleBarButtonStyle}"
                Click="OnMinimizeClicked">
          <iconPacks:PackIconMaterial Kind="WindowMinimize"
                                      Width="10"
                                      Height="10" />
        </Button>
        <Button Style="{StaticResource TitleBarButtonStyle}"
                Click="OnMaximizeRestoreClicked">
          <iconPacks:PackIconMaterial Kind="WindowMaximize"
                                      Width="10"
                                      Height="10" />
        </Button>
        <Button Style="{StaticResource TitleBarCloseButtonStyle}"
                Click="OnCloseClicked">
          <iconPacks:PackIconMaterial Kind="WindowClose"
                                      Width="10"
                                      Height="10" />
        </Button>
      </StackPanel>
    </Grid>
  </Grid>
</Window>
