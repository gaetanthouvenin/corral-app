<?xml version="1.0" encoding="utf-8"?>

<ResourceDictionary
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:sys="clr-namespace:System;assembly=System.Runtime">

  <!-- Color Palette - Modern Dark Theme -->
  <Color x:Key="ColorBackground">#141414</Color>
  <Color x:Key="ColorSurface">#1a1a1c</Color>
  <Color x:Key="ColorSurfaceVariant">#222225</Color>
  <Color x:Key="ColorBorder">#2d2d30</Color>
  <Color x:Key="ColorBorderLight">#3a3a3e</Color>
  <Color x:Key="ColorTextPrimary">#ffffff</Color>
  <Color x:Key="ColorTextSecondary">#a0a0a0</Color>
  <Color x:Key="ColorTextTertiary">#666666</Color>

  <!-- Accent Colors -->
  <Color x:Key="ColorAccent">#1a80e5</Color>
  <Color x:Key="ColorAccentHover">#2d93f8</Color>
  <Color x:Key="ColorAccentActive">#1867b5</Color>

  <!-- Status Colors -->
  <Color x:Key="ColorSuccess">#107c10</Color>
  <Color x:Key="ColorWarning">#ffb900</Color>
  <Color x:Key="ColorError">#d13438</Color>
  <Color x:Key="ColorInfo">#0078d4</Color>

  <!-- Zone Colors (Accent indicators) -->
  <Color x:Key="ColorZoneBlue">#1a80e5</Color>
  <Color x:Key="ColorZonePink">#ff5277</Color>
  <Color x:Key="ColorZoneCyan">#2bd2d2</Color>
  <Color x:Key="ColorZoneOrange">#ff9800</Color>
  <Color x:Key="ColorZonePurple">#a15bd7</Color>
  <Color x:Key="ColorZoneGray">#737373</Color>

</ResourceDictionary>
