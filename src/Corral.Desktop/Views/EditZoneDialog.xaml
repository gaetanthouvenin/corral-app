<?xml version="1.0" encoding="utf-8"?>

<Window
  x:Class="Corral.Desktop.Views.EditZoneDialog"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
  xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
  xmlns:viewModels="clr-namespace:Corral.Desktop.ViewModels"
  xmlns:loc="clr-namespace:Corral.Desktop.Localization"
  mc:Ignorable="d"
  d:DataContext="{d:DesignInstance Type=viewModels:EditZoneDialogViewModel, IsDesignTimeCreatable=True}"
  FocusManager.FocusedElement="{Binding ElementName=ZoneNameInput}"
  Title="{x:Static loc:Strings.EditZone_Title}"
  Width="480"
  Height="500"
  WindowStartupLocation="CenterOwner"
  ResizeMode="NoResize"
  ShowInTaskbar="False"
  WindowStyle="None"
  AllowsTransparency="True"
  Background="Transparent">

  <!-- Dialog Container with drop shadow -->
  <Border
    Margin="16"
    Background="{StaticResource BrushSurface}"
    CornerRadius="12">
    <Border.Effect>
      <DropShadowEffect Color="Black"
                        BlurRadius="24"
                        ShadowDepth="8"
                        Opacity="0.6" />
    </Border.Effect>

    <Grid>
      <Grid.RowDefinitions>
        <RowDefinition Height="52" />
        <RowDefinition Height="*" />
        <RowDefinition Height="72" />
      </Grid.RowDefinitions>

      <!-- ========================
           TITLE BAR
           ======================== -->
      <Border Grid.Row="0"
              Background="{StaticResource BrushSurfaceVariant}"
              CornerRadius="12,12,0,0">
        <Grid Margin="20,0,12,0">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
          </Grid.ColumnDefinitions>

          <StackPanel Grid.Column="0"
                      Orientation="Horizontal"
                      VerticalAlignment="Center">
            <iconPacks:PackIconMaterial Kind="Pencil"
                                        Width="18"
                                        Height="18"
                                        Foreground="{StaticResource BrushAccent}"
                                        VerticalAlignment="Center"
                                        Margin="0,0,10,0" />
            <TextBlock Text="{x:Static loc:Strings.EditZone_Header}"
                       FontSize="15"
                       FontWeight="SemiBold"
                       Foreground="{StaticResource BrushTextPrimary}"
                       VerticalAlignment="Center" />
          </StackPanel>

          <Button Grid.Column="1"
                  Command="{Binding CancelCommand}"
                  Width="32"
                  Height="32"
                  Cursor="Hand"
                  Background="Transparent"
                  BorderThickness="0">
            <Button.Template>
              <ControlTemplate TargetType="Button">
                <Border Background="{TemplateBinding Background}"
                        CornerRadius="6">
                  <ContentPresenter HorizontalAlignment="Center"
                                    VerticalAlignment="Center" />
                </Border>
                <ControlTemplate.Triggers>
                  <Trigger Property="IsMouseOver"
                           Value="True">
                    <Setter Property="Background"
                            Value="#22FFFFFF" />
                  </Trigger>
                </ControlTemplate.Triggers>
              </ControlTemplate>
            </Button.Template>
            <iconPacks:PackIconMaterial Kind="Close"
                                        Width="14"
                                        Height="14"
                                        Foreground="{StaticResource BrushTextSecondary}" />
          </Button>
        </Grid>
      </Border>

      <!-- ========================
           FORM CONTENT
           ======================== -->
      <StackPanel Grid.Row="1"
                  Margin="24,20,24,0">

        <!-- Zone Name -->
        <TextBlock Text="{x:Static loc:Strings.EditZone_NameLabel}"
                   Style="{StaticResource FieldLabel}" />
        <TextBox
          x:Name="ZoneNameInput"
          Text="{Binding ZoneName, UpdateSourceTrigger=PropertyChanged}"
          Style="{StaticResource InputField}"
          Margin="0,0,0,20" />

        <!-- Color Selection -->
        <TextBlock Text="{x:Static loc:Strings.EditZone_ColorLabel}"
                   Style="{StaticResource FieldLabel}" />

        <!-- Color Swatches (ItemsControl) -->
        <ItemsControl ItemsSource="{Binding ColorPresets}"
                      Margin="0,0,0,10">
          <ItemsControl.ItemsPanel>
            <ItemsPanelTemplate>
              <StackPanel Orientation="Horizontal" />
            </ItemsPanelTemplate>
          </ItemsControl.ItemsPanel>
          <ItemsControl.ItemTemplate>
            <DataTemplate DataType="{x:Type viewModels:ColorPreset}">
              <Button
                Style="{StaticResource ColorSwatchButton}"
                Background="{Binding Hex, Converter={StaticResource StringToColorConverter}}"
                Command="{Binding DataContext.SelectColorCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                CommandParameter="{Binding Hex}"
                ToolTip="{Binding Label}" />
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>

        <!-- Color Preview Bar -->
        <Border Height="36"
                CornerRadius="6"
                Margin="0,0,0,20"
                Background="{Binding ColorPreview}">
          <TextBlock
            Text="{Binding SelectedColor}"
            FontFamily="Consolas"
            FontSize="12"
            Foreground="White"
            HorizontalAlignment="Center"
            VerticalAlignment="Center" />
        </Border>

        <!-- Opacity Slider -->
        <TextBlock Text="{x:Static loc:Strings.EditZone_OpacityLabel}"
                   Style="{StaticResource FieldLabel}" />
        <Grid Margin="0,0,0,16">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="52" />
          </Grid.ColumnDefinitions>

          <Slider
            Grid.Column="0"
            Minimum="0"
            Maximum="100"
            Value="{Binding Opacity}"
            VerticalAlignment="Center"
            Margin="0,0,12,0" />

          <Border Grid.Column="1"
                  Background="{StaticResource BrushSurfaceVariant}"
                  BorderBrush="{StaticResource BrushBorder}"
                  BorderThickness="1"
                  CornerRadius="4">
            <TextBlock HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       Foreground="{StaticResource BrushTextPrimary}"
                       FontSize="13">
              <Run Text="{Binding Opacity}" /><Run Text="%" />
            </TextBlock>
          </Border>
        </Grid>

        <!-- Error Message -->
        <TextBlock
          Text="{Binding ErrorMessage}"
          Foreground="{StaticResource BrushError}"
          FontSize="12"
          TextWrapping="Wrap"
          Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibilityConverter}}" />

      </StackPanel>

      <!-- ========================
           ACTION BUTTONS
           ======================== -->
      <Border Grid.Row="2"
              BorderBrush="{StaticResource BrushBorder}"
              BorderThickness="0,1,0,0"
              CornerRadius="0,0,12,12">
        <Grid Margin="24,0">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="Auto" />
          </Grid.ColumnDefinitions>

          <!-- Loading indicator -->
          <TextBlock Grid.Column="0"
                     Text="{x:Static loc:Strings.EditZone_Saving}"
                     FontSize="12"
                     Foreground="{StaticResource BrushTextSecondary}"
                     VerticalAlignment="Center"
                     Visibility="{Binding IsUpdating, Converter={StaticResource BoolToVisibilityConverter}}" />

          <!-- Cancel Button -->
          <Button Grid.Column="1"
                  Content="{x:Static loc:Strings.EditZone_Cancel}"
                  Command="{Binding CancelCommand}"
                  Style="{StaticResource ButtonSecondary}"
                  Margin="0,0,8,0" />

          <!-- Update Button -->
          <Button Grid.Column="2"
                  Command="{Binding UpdateZoneCommand}"
                  Style="{StaticResource ButtonPrimary}">
            <StackPanel Orientation="Horizontal">
              <iconPacks:PackIconMaterial Kind="Pencil"
                                          Width="14"
                                          Height="14"
                                          VerticalAlignment="Center"
                                          Margin="0,0,6,0" />
              <TextBlock Text="{x:Static loc:Strings.EditZone_Submit}"
                         VerticalAlignment="Center" />
            </StackPanel>
          </Button>
        </Grid>
      </Border>
    </Grid>
  </Border>
</Window>
