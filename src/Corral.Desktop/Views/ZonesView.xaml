<UserControl x:Class="Corral.Desktop.Views.ZonesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
             xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks">

  <ScrollViewer VerticalScrollBarVisibility="Auto"
                Margin="48,16,48,0">
    <StackPanel>
      <!-- Breadcrumb & Header -->
      <TextBlock FontSize="10"
                 FontWeight="SemiBold"
                 Foreground="{StaticResource BrushTextTertiary}"
                 Margin="0,0,0,24"
                 Text="CORRAL MANAGER / ACTIVE ZONES" />

      <Grid Margin="0,0,0,48">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>

        <!-- Title Section -->
        <StackPanel Grid.Column="0"
                    VerticalAlignment="Center">
          <TextBlock
            Text="Corral Manager"
            FontSize="32"
            FontWeight="Bold"
            Foreground="{StaticResource BrushTextPrimary}"
            Margin="0,0,0,8" />
          <TextBlock
            Text="Simplify your workspace by managing active zones."
            FontSize="15"
            Foreground="{StaticResource BrushTextSecondary}" />
          <TextBlock
            Text="Toggle or edit environments below."
            FontSize="15"
            Foreground="{StaticResource BrushTextSecondary}" />
        </StackPanel>

        <!-- Create Button -->
        <StackPanel Grid.Column="1"
                    Orientation="Horizontal"
                    VerticalAlignment="Center">
          <!-- Toggle Overlays Button -->
          <Button
            Command="{Binding ToggleOverlaysCommand}"
            Style="{StaticResource ButtonPrimary}"
            Height="44"
            Padding="24,0"
            Margin="0,0,12,0"
            WindowChrome.IsHitTestVisibleInChrome="True">
            <StackPanel Orientation="Horizontal">
              <iconPacks:PackIconMaterial Kind="Monitor"
                                          Width="14"
                                          Height="14"
                                          Margin="0,0,8,0"
                                          VerticalAlignment="Center" />
              <TextBlock FontSize="14"
                         FontWeight="SemiBold"
                         VerticalAlignment="Center">
                <TextBlock.Style>
                  <Style TargetType="TextBlock">
                    <Setter Property="Text"
                            Value="Show Overlays" />
                    <Style.Triggers>
                      <DataTrigger Binding="{Binding AreOverlaysVisible}"
                                   Value="True">
                        <Setter Property="Text"
                                Value="Hide Overlays" />
                      </DataTrigger>
                    </Style.Triggers>
                  </Style>
                </TextBlock.Style>
              </TextBlock>
            </StackPanel>
            <Button.Resources>
              <Style TargetType="Border">
                <Setter Property="CornerRadius"
                        Value="6" />
              </Style>
            </Button.Resources>
          </Button>

          <!-- Create New Zone Button -->
          <Button
            Command="{Binding CreateNewZoneCommand}"
            Style="{StaticResource ButtonPrimary}"
            Height="44"
            Padding="24,0"
            WindowChrome.IsHitTestVisibleInChrome="True">
            <StackPanel Orientation="Horizontal">
              <TextBlock Text="+"
                         FontSize="20"
                         FontWeight="Bold"
                         Margin="0,-2,6,0" />
              <TextBlock Text="Create Zone"
                         FontSize="14"
                         FontWeight="SemiBold"
                         VerticalAlignment="Center" />
            </StackPanel>
            <Button.Resources>
              <Style TargetType="Border">
                <Setter Property="CornerRadius"
                        Value="6" />
              </Style>
            </Button.Resources>
          </Button>
        </StackPanel>
      </Grid>

      <!-- Zones Grid -->
      <ItemsControl
        ItemsSource="{Binding Fences}"
        ItemTemplate="{StaticResource ZoneCardTemplate}">
        <ItemsControl.ItemsPanel>
          <ItemsPanelTemplate>
            <UniformGrid Columns="3" />
          </ItemsPanelTemplate>
        </ItemsControl.ItemsPanel>
      </ItemsControl>
    </StackPanel>
  </ScrollViewer>
</UserControl>
