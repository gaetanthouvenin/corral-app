<UserControl x:Class="Corral.Desktop.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks">
  <ScrollViewer VerticalScrollBarVisibility="Auto"
                Margin="48,24,48,24">
    <StackPanel>

      <!-- Breadcrumb -->
      <TextBlock FontSize="10"
                 FontWeight="SemiBold"
                 Foreground="{StaticResource BrushTextTertiary}"
                 Margin="0,0,0,24"
                 Text="CORRAL MANAGER / PARAMÈTRES" />

      <!-- Title -->
      <TextBlock Text="Paramètres"
                 FontSize="32"
                 FontWeight="Bold"
                 Foreground="{StaticResource BrushTextPrimary}"
                 Margin="0,0,0,8" />
      <TextBlock Text="Configurez le comportement des overlays."
                 FontSize="15"
                 Foreground="{StaticResource BrushTextSecondary}"
                 Margin="0,0,0,48" />

      <!-- Click Mode Section -->
      <TextBlock Text="MODE DE CLIC"
                 FontSize="11"
                 FontWeight="SemiBold"
                 Foreground="{StaticResource BrushTextTertiary}"
                 Margin="0,0,0,12" />
      <TextBlock Text="Choisissez comment ouvrir les éléments dans les overlays."
                 FontSize="13"
                 Foreground="{StaticResource BrushTextSecondary}"
                 Margin="0,0,0,16" />

      <StackPanel Orientation="Horizontal"
                  Margin="0,0,0,40">
        <!-- Single Click -->
        <RadioButton
          IsChecked="{Binding SelectedClickMode, Converter={StaticResource EnumToBoolConverter}, ConverterParameter=0}"
          Style="{StaticResource RadioButtonIconOption}"
          Margin="0,0,12,0"
          MinWidth="140">
          <StackPanel HorizontalAlignment="Center">
            <iconPacks:PackIconMaterial Kind="CursorDefaultClick"
                                        Width="28"
                                        Height="28"
                                        HorizontalAlignment="Center"
                                        Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=RadioButton}}"
                                        Margin="0,0,0,8" />
            <TextBlock Text="Simple clic"
                       FontSize="12"
                       FontWeight="SemiBold"
                       HorizontalAlignment="Center"
                       Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=RadioButton}}" />
            <TextBlock Text="Un clic pour ouvrir"
                       FontSize="11"
                       HorizontalAlignment="Center"
                       Foreground="{StaticResource BrushTextTertiary}"
                       Margin="0,4,0,0" />
          </StackPanel>
        </RadioButton>

        <!-- Double Click -->
        <RadioButton
          IsChecked="{Binding SelectedClickMode, Converter={StaticResource EnumToBoolConverter}, ConverterParameter=1}"
          Style="{StaticResource RadioButtonIconOption}"
          MinWidth="140">
          <StackPanel HorizontalAlignment="Center">
            <Grid Width="28"
                  Height="28"
                  Margin="0,0,0,8"
                  HorizontalAlignment="Center">
              <iconPacks:PackIconMaterial Kind="CursorDefaultClick"
                                          Width="28"
                                          Height="28"
                                          Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=RadioButton}}" />
              <TextBlock Text="×2"
                         FontSize="9"
                         FontWeight="Bold"
                         HorizontalAlignment="Right"
                         VerticalAlignment="Bottom"
                         Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=RadioButton}}" />
            </Grid>
            <TextBlock Text="Double clic"
                       FontSize="12"
                       FontWeight="SemiBold"
                       HorizontalAlignment="Center"
                       Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=RadioButton}}" />
            <TextBlock Text="Deux clics pour ouvrir"
                       FontSize="11"
                       HorizontalAlignment="Center"
                       Foreground="{StaticResource BrushTextTertiary}"
                       Margin="0,4,0,0" />
          </StackPanel>
        </RadioButton>
      </StackPanel>

      <!-- Icon Layout Section -->
      <TextBlock Text="ORGANISATION DES ICÔNES"
                 FontSize="11"
                 FontWeight="SemiBold"
                 Foreground="{StaticResource BrushTextTertiary}"
                 Margin="0,0,0,12" />
      <TextBlock Text="Choisissez comment les éléments sont affichés dans les overlays."
                 FontSize="13"
                 Foreground="{StaticResource BrushTextSecondary}"
                 Margin="0,0,0,16" />

      <StackPanel Orientation="Horizontal"
                  Margin="0,0,0,48">
        <!-- Large Grid -->
        <RadioButton
          IsChecked="{Binding SelectedIconLayout, Converter={StaticResource EnumToBoolConverter}, ConverterParameter=0}"
          Style="{StaticResource RadioButtonIconOption}"
          Margin="0,0,12,0"
          MinWidth="120">
          <StackPanel HorizontalAlignment="Center">
            <iconPacks:PackIconMaterial Kind="ViewGridPlus"
                                        Width="28"
                                        Height="28"
                                        HorizontalAlignment="Center"
                                        Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=RadioButton}}"
                                        Margin="0,0,0,8" />
            <TextBlock Text="Grandes icônes"
                       FontSize="12"
                       FontWeight="SemiBold"
                       HorizontalAlignment="Center"
                       Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=RadioButton}}" />
          </StackPanel>
        </RadioButton>

        <!-- Small Grid -->
        <RadioButton
          IsChecked="{Binding SelectedIconLayout, Converter={StaticResource EnumToBoolConverter}, ConverterParameter=1}"
          Style="{StaticResource RadioButtonIconOption}"
          Margin="0,0,12,0"
          MinWidth="120">
          <StackPanel HorizontalAlignment="Center">
            <iconPacks:PackIconMaterial Kind="ViewGrid"
                                        Width="28"
                                        Height="28"
                                        HorizontalAlignment="Center"
                                        Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=RadioButton}}"
                                        Margin="0,0,0,8" />
            <TextBlock Text="Petites icônes"
                       FontSize="12"
                       FontWeight="SemiBold"
                       HorizontalAlignment="Center"
                       Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=RadioButton}}" />
          </StackPanel>
        </RadioButton>

        <!-- List -->
        <RadioButton
          IsChecked="{Binding SelectedIconLayout, Converter={StaticResource EnumToBoolConverter}, ConverterParameter=2}"
          Style="{StaticResource RadioButtonIconOption}"
          MinWidth="120">
          <StackPanel HorizontalAlignment="Center">
            <iconPacks:PackIconMaterial Kind="ViewList"
                                        Width="28"
                                        Height="28"
                                        HorizontalAlignment="Center"
                                        Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=RadioButton}}"
                                        Margin="0,0,0,8" />
            <TextBlock Text="Liste"
                       FontSize="12"
                       FontWeight="SemiBold"
                       HorizontalAlignment="Center"
                       Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=RadioButton}}" />
          </StackPanel>
        </RadioButton>
      </StackPanel>

      <!-- Buttons -->
      <StackPanel Orientation="Horizontal">
        <Button Command="{Binding SaveSettingsCommand}"
                Style="{StaticResource ButtonPrimary}"
                Height="44"
                Padding="24,0"
                Margin="0,0,8,0"
                WindowChrome.IsHitTestVisibleInChrome="True">
          <TextBlock Text="Enregistrer"
                     FontSize="14"
                     FontWeight="SemiBold"
                     VerticalAlignment="Center" />
          <Button.Resources>
            <Style TargetType="Border">
              <Setter Property="CornerRadius" Value="6" />
            </Style>
          </Button.Resources>
        </Button>
        <Button Command="{Binding ResetDefaultsCommand}"
                Background="Transparent"
                BorderBrush="{StaticResource BrushTextSecondary}"
                BorderThickness="1"
                Foreground="{StaticResource BrushTextSecondary}"
                Height="44"
                Padding="24,0"
                WindowChrome.IsHitTestVisibleInChrome="True">
          <TextBlock Text="Réinitialiser"
                     FontSize="14"
                     FontWeight="SemiBold"
                     VerticalAlignment="Center" />
          <Button.Resources>
            <Style TargetType="Border">
              <Setter Property="CornerRadius" Value="6" />
            </Style>
          </Button.Resources>
        </Button>
      </StackPanel>

    </StackPanel>
  </ScrollViewer>
</UserControl>
