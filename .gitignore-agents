## Code Templates

### Command Template
```csharp
using System;
using Corral.Application.DTOs;
using Corral.Domain.Contracts.CQRS;

namespace Corral.Application.Commands.CreateFence;

/// <summary>
/// Command to create a new fence.
/// </summary>
/// <remarks>
/// This command initiates the creation of a fence with specified properties.
/// Validation ensures all parameters are within acceptable ranges.
/// </remarks>
public record CreateFenceCommand(
    string Name,
    int PositionX,
    int PositionY,
    int Width,
    int Height,
    string BackgroundColor,
    int Opacity
) : ICommand<FenceDto>;
```

### CommandValidator Template
```csharp
using FluentValidation;
using Corral.Application.Commands.CreateFence;

namespace Corral.Application.Commands.CreateFence;

/// <summary>
/// Validator for CreateFenceCommand.
/// Ensures all command properties meet business requirements.
/// </summary>
public class CreateFenceCommandValidator : AbstractValidator<CreateFenceCommand>
{
    public CreateFenceCommandValidator()
    {
        RuleFor(cmd => cmd.Name)
            .NotEmpty().WithMessage("Name is required")
            .MaximumLength(255).WithMessage("Name must not exceed 255 characters");

        RuleFor(cmd => cmd.Width)
            .InclusiveBetween(50, 2560).WithMessage("Width must be between 50 and 2560 pixels");

        RuleFor(cmd => cmd.Height)
            .InclusiveBetween(50, 1440).WithMessage("Height must be between 50 and 1440 pixels");

        RuleFor(cmd => cmd.Opacity)
            .InclusiveBetween(0, 100).WithMessage("Opacity must be between 0 and 100");
    }
}
```

### CommandHandler Template
```csharp
using System.Threading;
using System.Threading.Tasks;
using MediatR;
using Corral.Application.Commands.CreateFence;
using Corral.Application.DTOs;
using Corral.Application.Mappers;
using Corral.Domain.Aggregates;
using Corral.Domain.ValueObjects;
using Corral.Infrastructure.UnitOfWork;

namespace Corral.Application.Commands.CreateFence;

/// <summary>
/// Handler for CreateFenceCommand.
/// Creates a new fence in the system.
/// </summary>
public class CreateFenceCommandHandler : IRequestHandler<CreateFenceCommand, FenceDto>
{
    private readonly IUnitOfWork _unitOfWork;
    private readonly FenceDomainToDtoMapper _mapper;

    public CreateFenceCommandHandler(IUnitOfWork unitOfWork)
    {
        _unitOfWork = unitOfWork;
        _mapper = new FenceDomainToDtoMapper();
    }

    public async Task<FenceDto> Handle(CreateFenceCommand request, CancellationToken cancellationToken)
    {
        // Create domain entities
        var position = new Position(request.PositionX, request.PositionY);
        var dimensions = new Dimensions(request.Width, request.Height);
        var color = Color.FromHexString(request.BackgroundColor);
        var opacity = new Opacity(request.Opacity);

        // Create the aggregate root
        var fence = Fence.Create(request.Name, position, dimensions, color, opacity);

        // Persist
        _unitOfWork.Fences.Add(fence);
        await _unitOfWork.SaveChangesAsync(cancellationToken);

        // Map and return
        return _mapper.Map(fence);
    }
}
```

